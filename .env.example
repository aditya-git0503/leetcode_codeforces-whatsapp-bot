# ─── LeetCode WhatsApp Bot — Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.

# Your LeetCode username  (from leetcode.com/u/YOUR_USERNAME)
LEETCODE_USERNAME=your_leetcode_username

# WhatsApp recipient number — country code + number, NO + or spaces
# Example for India: 919876543210
RECIPIENT_NUMBER=919876543210

# Path to python3 on your machine (usually fine as-is)
PYTHON_BIN=python3
